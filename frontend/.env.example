# Canonical frontend URL — REQUIRED in production.
# Set to https://ocasia.vercel.app in Vercel env vars.
# Omit (or leave blank) for local dev — falls back to window.location.origin.
VITE_APP_URL=

# Backend APIs
VITE_DJANGO_API_URL=http://localhost:8000/api
VITE_FASTAPI_URL=http://localhost:8001

# Google OAuth
VITE_GOOGLE_CLIENT_ID=

# Google Apps Script — Contact Form
VITE_GAS_CONTACT_URL=

# EmailJS — Auth emails (verification, password reset)
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_VERIFY=
VITE_EMAILJS_TEMPLATE_RESET=
VITE_EMAILJS_TEMPLATE_WELCOME=
